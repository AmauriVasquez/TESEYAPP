# SPA fallback: rutas profundas (/clientes, /operaciones/proyectos/12, ...)
# se sirven con index.html; los archivos reales se sirven tal cual.
Options -MultiViews
RewriteEngine On
RewriteBase /

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]

<IfModule mod_headers.c>
  # El HTML nunca se cachea: cada visita toma la version recien desplegada.
  # (Sin esto, el cache heuristico del navegador servia versiones viejas
  # durante horas despues de cada deploy manual.)
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # Assets con hash de Vite en el nombre (index-Ab12Cd34.js): inmutables.
  # Los logos sin hash (brand-*.png) NO entran aqui a proposito.
  <FilesMatch "-[A-Za-z0-9_-]{8,}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
